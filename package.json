{
  "name": "swipeverse",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write '**/*.{ts,tsx,json,css,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,css,md}'",
    "check": "tsc --noEmit && eslint . --ext .ts,.tsx --max-warnings 0",
    "generate:decks": "node scripts/generate-decks.mjs",
    "analyze:decks": "node scripts/analyze-decks.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^1.12.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.0"
  }
}
